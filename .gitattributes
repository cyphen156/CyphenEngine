# Normalize all text files to LF in the repository.
# Source/text types are pinned to LF in the working tree too (eol=lf overrides
# core.autocrlf), so Windows/MSVC and Linux/WSL2 see identical LF endings.
* text=auto

# Explicit text types — LF in working tree (deterministic across machines)
*.cpp   text eol=lf
*.cc    text eol=lf
*.cxx   text eol=lf
*.c     text eol=lf
*.h     text eol=lf
*.hpp   text eol=lf
*.hxx   text eol=lf
*.inl   text eol=lf
*.cs    text eol=lf
*.md    text eol=lf
*.txt   text eol=lf
*.json  text eol=lf
*.xml   text eol=lf
*.props text eol=lf
*.targets text eol=lf

# Visual Studio project/solution files: keep CRLF in working tree
# (VS rewrites them as CRLF; pinning avoids churn)
*.sln     text eol=crlf
*.vcxproj text eol=crlf
*.vcxproj.filters text eol=crlf

# Binary assets — never touch
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.bmp  binary
*.dds  binary
*.tga  binary
*.ico  binary
*.ttf  binary
*.otf  binary
*.lib  binary
*.dll  binary
*.exe  binary
*.pdb  binary
*.ilk  binary
*.obj  binary
*.pch  binary
